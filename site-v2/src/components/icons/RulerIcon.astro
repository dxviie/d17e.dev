---
interface Props {
  color?: string;
  size?: string;
}

const { color = "currentColor", size = "1em" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={color}
  xmlns="http://www.w3.org/2000/svg"
>
  <rect x="3" y="3" width="18" height="18" rx="1" ry="1" fill="none" stroke={color} stroke-width="2"/>
</svg>
