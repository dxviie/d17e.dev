---
import type {CollectionEntry} from 'astro:content';
import {ClientRouter} from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Markdown from '../components/Markdown.astro';
import MediaAsset from '../components/MediaAsset.astro';
import '../styles/markdown.css';
import FindMeOn from "../components/FindMeOn.astro";
import PostPrevNextMini from "../components/PostPrevNextMini.astro";
import DraftIndicator from "../components/DraftIndicator.astro";
import ShareOn from "../components/ShareOn.astro";
import { getOgImageUrl, getVideoPosterUrl, getOriginalExtension, getImageUrl } from "../utils/mediaUrls";

type Props = CollectionEntry<'posts'>['data'];

const {slug, title, publishDate, dateUpdated, cover, body, link, linkDescription, status, gallery} = Astro.props;

// Cover first, then gallery items
const mediaItems = cover ? [cover, ...(gallery || [])] : [...(gallery || [])];
const hasGallery = mediaItems.length > 1;

const isVideo = cover.type?.startsWith("video/");
// Use CDN URL for OG image (best available size up to 1200w)
let imageUrl = isVideo ? getVideoPosterUrl(cover.id) : getOgImageUrl(cover.id, cover.width, getOriginalExtension(cover.filenameDownload, cover.type));

function getThumbUrl(item: { id: string; type?: string }) {
    if (!item?.id) return "";
    return item.type?.startsWith("video/")
        ? getVideoPosterUrl(item.id)
        : getImageUrl(item.id, "400w");
}
---

<html lang="en">
<head>
  <BaseHead title={title} description={linkDescription || ''} image={imageUrl}/>
  <ClientRouter/>
</head>

<body>
<div class="statusbar"/>
<Header/>
<main class="content-margin">
  <article class="post-container">
    <DraftIndicator status={status}/>
    {cover && (
            <div class="hero-media">
              {hasGallery ? (
                <div class="post-slides">
                  {mediaItems.map((item, i) => (
                    <div
                      class="post-slide"
                      data-index={i}
                      data-active={i === 0 ? "true" : "false"}
                    >
                      <MediaAsset
                        id={item.id}
                        title={item.title}
                        alt={item.title || title}
                        type={item.type}
                        filenameDownload={item.filenameDownload}
                        originalWidth={item.width}
                        originalHeight={item.height}
                        isHero={true}
                        objectFit="contain"
                        blurhash={item.blurhash}
                      />
                    </div>
                  ))}
                </div>
              ) : (
                <MediaAsset
                        id={cover.id}
                        title={cover.title}
                        alt={cover.title || title}
                        type={cover.type}
                        filenameDownload={cover.filenameDownload}
                        originalWidth={cover.width}
                        originalHeight={cover.height}
                        isHero={true}
                        objectFit="contain"
                        blurhash={cover.blurhash}
                />
              )}
              <PostPrevNextMini currentSlug={slug}/>
            </div>
    )}

    {hasGallery && (
      <div class="gallery-thumbs gallery-thumbs-mobile" role="tablist">
        {mediaItems.map((item, i) => (
          <button
            type="button"
            class="gallery-thumb"
            data-index={i}
            aria-pressed={i === 0 ? "true" : "false"}
            aria-label={`View image ${i + 1}`}
          >
            <img
              src={getThumbUrl(item)}
              alt=""
              width={64}
              height={64}
              loading="lazy"
            />
          </button>
        ))}
      </div>
    )}

    <div class="post-content">
      <div class="title-section">
        <span class="date">
          {publishDate &&
                  <FormattedDate date={publishDate}/>}
          {dateUpdated && (
                  <span class="last-updated">
                  · Last updated: <FormattedDate date={dateUpdated}/>
                </span>
          )}
        </span>
        <h1>{title}</h1>
      </div>

      {/* Parse Markdown content */}
      <Markdown content={body}/>

      {link && (
              <span class="link-section">
                🔗
                <a href={link} target="_blank" rel="noopener noreferrer">{linkDescription || link}</a>
              </span>
      )}

      {hasGallery && (
        <div class="gallery-thumbs gallery-thumbs-desktop" role="tablist">
          {mediaItems.map((item, i) => (
            <button
              type="button"
              class="gallery-thumb"
              data-index={i}
              aria-pressed={i === 0 ? "true" : "false"}
              aria-label={`View image ${i + 1}`}
            >
              <img
                src={getThumbUrl(item)}
                alt=""
                width={64}
                height={64}
                loading="lazy"
              />
            </button>
          ))}
        </div>
      )}

      <ShareOn title={title} description={linkDescription || ''} />
    </div>
  </article>

  <slot/>
</main>
<FindMeOn/>
<Footer/>
</body>
</html>

<style>
    main {
        width: 90%;
        max-width: 960px;
        padding: 2rem 1rem;
        min-height: calc(100vh - 30rem);
        /* margin now handled by content-margin class */
    }

    .hero-media {
        width: 100%;
        margin-bottom: 0;
    }

    .post-content {
        color: var(--color);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .title-section {
        margin-bottom: 2rem;
    }

    .title-section h1 {
        font-family: 'nudica_monobold', serif;
        margin: 0.5rem 0;
        font-size: 2.5rem;
        line-height: 1.2;
    }

    .date {
        font-family: 'nudica_monolight', serif;
        background-color: var(--color);
        color: var(--bg-color);
        padding: 0.2rem 0.5rem;
        font-size: 0.9rem;
    }

    .last-updated {
        font-style: italic;
        font-size: 0.85rem;
    }

    .link-section {
        font-family: 'nudica_monolight', serif;
        display: inline-block;
        margin: 1.5rem 0;
        padding: 1rem;
        background-color: var(--bg-code);
        border-radius: 8px;
    }

    .link-section a {
        color: var(--accent-color);
        text-decoration: none;
        word-break: break-all;
    }

    .link-section a:hover {
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        .link-section {
            flex-direction: column;
            align-items: flex-start;
        }

        .title-section h1 {
            font-size: 2rem;
        }
    }

    article.post-container {
        display: flex;
        flex-direction: column;
        position: relative;
    }

    /* Gallery slides — use grid stack so the tallest slide drives container height */
    .post-slides {
        display: grid;
        width: 100%;
    }

    .post-slide {
        grid-area: 1 / 1;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
    }

    .post-slide[data-active="true"] {
        opacity: 1;
        pointer-events: auto;
        z-index: 1;
    }

    /* Gallery thumbs */
    .gallery-thumbs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .gallery-thumbs-mobile {
        display: flex;
    }

    .gallery-thumbs-desktop {
        display: none;
    }

    .gallery-thumb {
        width: 64px;
        height: 64px;
        padding: 0;
        border: 2px solid transparent;
        border-radius: 8px;
        background: rgba(var(--gray-light), 0.1);
        cursor: pointer;
        overflow: hidden;
        transition:
            border-color 0.2s,
            opacity 0.2s;
    }

    .gallery-thumb:hover {
        opacity: 0.9;
    }

    .gallery-thumb[aria-pressed="true"] {
        border-color: var(--color);
    }

    .gallery-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 0;
    }

    @media (min-width: 1200px) {
        main {
            max-width: 90vw;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .hero-media {
            flex: 0 0 calc(55% - 1rem);
            min-width: 0;
        }

        .post-content {
            flex: 0 0 calc(45% - 1rem);
            min-width: 0;
        }

        article {
            width: 100%;
            max-width: 1400px;
            justify-content: center;
            flex-direction: row !important;
            gap: 2rem;
        }

        .gallery-thumbs-mobile {
            display: none;
        }

        .gallery-thumbs-desktop {
            display: flex;
        }

    }
</style>

<script>
  // Add click handler to make video controls appear when clicking on video
  document.addEventListener('DOMContentLoaded', () => {
    const videos = document.querySelectorAll('video');

    videos.forEach(video => {
      video.addEventListener('click', () => {
        video.controls = !video.controls;
      });
    });
  });

  function initGallery() {
    const slides = document.querySelectorAll('.post-slide');
    const thumbs = document.querySelectorAll('.gallery-thumb');

    if (slides.length === 0 || thumbs.length === 0) return;

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = thumb.getAttribute('data-index');
        if (index == null) return;

        slides.forEach((s) => s.setAttribute('data-active', 'false'));
        thumbs.forEach((t) => t.setAttribute('aria-pressed', 'false'));

        const slide = document.querySelector(`.post-slide[data-index="${index}"]`);
        if (slide) slide.setAttribute('data-active', 'true');
        thumb.setAttribute('aria-pressed', 'true');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initGallery);
  document.addEventListener('astro:page-load', initGallery);
</script>
