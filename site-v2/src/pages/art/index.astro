---
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import BaseHead from "../../components/BaseHead.astro";
import MediaAsset from "../../components/MediaAsset.astro";
import FindMeOn from "../../components/FindMeOn.astro";

const artItems = (await getCollection("art")).sort(
  (a, b) =>
    (b.data.publishDate?.valueOf() || 0) - (a.data.publishDate?.valueOf() || 0),
);
---

<!doctype html>
<html lang="en">
  <head>
    <title>{SITE_TITLE} | Art</title>
    <BaseHead title={`${SITE_TITLE} | Art`} description={SITE_DESCRIPTION} />
    <style>
      main {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 1800px;
        padding: 2rem 1rem;
        overflow-x: hidden;
        box-sizing: border-box;
      }

      @media (max-width: 720px), (max-width: 1024px) {
        main {
          padding: 1em;
        }
      }

      .page-title {
        font-family: "nudica_monobold", serif;
        margin: 0 0 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.5rem;
        font-size: 1.5rem;
      }

      .art-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
        gap: 2.5rem;
        list-style: none;
        margin: 0;
        margin-top: 1.3rem;
        padding: 0;
      }

      @media (max-width: 720px) {
        .art-grid {
          gap: 1.5rem;
        }
      }

      .art-item {
        background: rgba(var(--gray-light), 0.05);
        border-radius: 6px;
        overflow: hidden;
        transition: all 0.3s ease;
      }

      .art-item:hover {
        transform: translateY(-4px);
        box-shadow: var(--box-shadow);
      }

      .art-item a {
        display: block;
        text-decoration: none;
        color: var(--color);
      }

      .art-cover {
        position: relative;
        width: 100%;
        aspect-ratio: 1;
        overflow: hidden;
      }

      .art-title {
        font-family: "nudica_monobold", serif;
        margin: 0;
        padding: 1.25rem;
        font-size: 1.15rem;
        line-height: 1.3;
      }

      .art-date {
        font-family: "nudica_monolight", serif;
        font-size: 0.85rem;
        padding: 0 1.25rem 1.25rem;
        opacity: 0.8;
      }
    </style>
  </head>
  <body data-art-page="true">
    <Header />
    <div class="statusbar"></div>
    <main class="content-margin">
      <ul class="art-grid">
        {
          artItems.map((item, index) => (
            <li class="art-item">
              <a href={`/art/${item.data.slug}/`}>
                {item.data.cover && (
                  <div class="art-cover">
                    <MediaAsset
                      id={item.data.cover.id}
                      title={item.data.cover.title}
                      alt={item.data.cover.title || item.data.title}
                      type={item.data.cover.type}
                      filenameDownload={item.data.cover.filenameDownload}
                      originalWidth={item.data.cover.width}
                      originalHeight={item.data.cover.height}
                      width={400}
                      height={400}
                      loading={index < 12 ? "eager" : "lazy"}
                    />
                  </div>
                )}
                <h2 class="art-title">{item.data.title}</h2>
                {item.data.publishDate && (
                  <span class="art-date">
                    <FormattedDate date={item.data.publishDate} format="MMM YYYY" />
                  </span>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <FindMeOn />
    <Footer />
  </body>
</html>
